<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_background"
    android:maxHeight="400dp">

    <!-- 顶部拖拽条 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#CCCCCC" />

    <!-- 状态提示 -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="准备就绪"
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"
        android:padding="8dp" />

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- 输出区域 -->
    <ScrollView
        android:id="@+id/outputScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FAFAFA"
        android:padding="12dp">

        <TextView
            android:id="@+id/outputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="15sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp" />
    </ScrollView>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- 输入区域 - ViewFlipper 切换语音/文本模式 -->
    <ViewFlipper
        android:id="@+id/inputFlipper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 语音输入模式 -->
        <LinearLayout
            android:id="@+id/voiceInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/micButton"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:padding="12dp" />

            <TextView
                android:id="@+id/micHintText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击说话"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tapToTypeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="或点击此处输入文字"
                android:textSize="13sp"
                android:textColor="#2196F3"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp" />
        </LinearLayout>

        <!-- 文本输入模式 -->
        <LinearLayout
            android:id="@+id/textInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/textInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="输入消息..."
                android:inputType="text|textMultiLine"
                android:maxLines="4"
                android:padding="12dp"
                android:background="#F0F0F0"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/sendButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_send"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="发送" />

            <ImageButton
                android:id="@+id/voiceModeButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="语音模式" />
        </LinearLayout>
    </ViewFlipper>

</LinearLayout>
